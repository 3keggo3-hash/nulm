{
  "blocked_shell_patterns": [],
  "sensitive_path_patterns": [
    ".env",
    "*.secret",
    "credentials/*",
    "secrets/*"
  ],
  "secret_patterns": {
    "aws_access_key": "AKIA[0-9A-Z]{16}",
    "aws_secret_key": "(?i)aws[_-]?secret[_-]?access[_-]?key\\s*[:=]\\s*['\"]?[A-Za-z0-9/+=]{40}['\"]?",
    "github_token": "gh[ps]_[A-Za-z0-9_]{36,}",
    "slack_token": "xox[baprs]-[A-Za-z0-9\\-]{10,}",
    "private_key_block": "-----BEGIN PRIVATE KEY-----",
    "generic_password": "(?i)password\\s*[:=]\\s*['\"]?[^\\s'\"]{8,}['\"]?"
  },
  "rules": [
    {
      "name": "deny-write-env-files",
      "description": "Block writing to environment files containing secrets",
      "action": "deny",
      "priority": 5,
      "enabled": true,
      "conditions": [
        {
          "type": "tool",
          "field": "tool",
          "value": "write_file"
        },
        {
          "type": "extension",
          "field": "path",
          "value": ".env"
        }
      ]
    },
    {
      "name": "ask-when-secret-pattern-detected",
      "description": "Ask for approval when content contains secrets",
      "action": "ask",
      "priority": 20,
      "enabled": true,
      "conditions": [
        {
          "type": "content_contains",
          "field": "content",
          "value": "AKIA"
        }
      ]
    }
  ],
  "metadata": {
    "name": "masked-secret",
    "description": "Demo: secret pattern masking and sensitive path protection",
    "scenario": "masked_secret"
  }
}