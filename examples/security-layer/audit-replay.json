{
  "blocked_shell_patterns": [
    "sudo *",
    "mkfs *"
  ],
  "sensitive_path_patterns": [
    "/etc/shadow",
    "/etc/passwd",
    ".ssh/*",
    ".gnupg/*"
  ],
  "secret_patterns": {
    "aws_access_key": "AKIA[0-9A-Z]{16}",
    "github_token": "gh[ps]_[A-Za-z0-9_]{36,}",
    "generic_api_key": "(?i)api[_-]?key\\s*[:=]\\s*['\"]?[A-Za-z0-9_\\-]{20,}['\"]?"
  },
  "rules": [
    {
      "name": "deny-sensitive-path-access",
      "description": "Block access to OS sensitive files",
      "action": "deny",
      "priority": 10,
      "enabled": true,
      "conditions": [
        {
          "type": "tool",
          "field": "tool",
          "value": "read_file"
        },
        {
          "type": "sensitive_path",
          "field": "path",
          "value": "/etc/*"
        }
      ]
    },
    {
      "name": "deny-write-to-ssh-dir",
      "description": "Block writes to SSH directory",
      "action": "deny",
      "priority": 5,
      "enabled": true,
      "conditions": [
        {
          "type": "glob",
          "field": "path",
          "value": ".ssh/**"
        }
      ]
    }
  ],
  "metadata": {
    "name": "audit-replay",
    "description": "Demo: policy for auditing and replaying tool call decisions",
    "scenario": "audit_replay"
  }
}